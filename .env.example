APP_NAME=SuturaMed
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- Base de données (Render fournit DATABASE_URL automatiquement) ---
DB_CONNECTION=pgsql
DATABASE_URL=                     # Fourni par Render si base liée

# --- Session & Cache (file = pas de redis nécessaire) ---
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# --- IA Triage ---
GEMINI_API_KEY=                   # Clé Google Gemini API

# --- Local dev uniquement ---
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=sutura
# DB_USERNAME=sutura
# DB_PASSWORD=secret
